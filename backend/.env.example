APP_NAME="Trader Inventory API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=trader_inventory
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000
SESSION_DOMAIN=localhost
SPA_URL=http://localhost:5173

MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=brevo_smtp_username
MAIL_PASSWORD=brevo_smtp_password
MAIL_FROM_ADDRESS="info@smatatech.com.ng"
MAIL_FROM_NAME="${APP_NAME}"



# Brevo API Configuration
BREVO_API_KEY=
BREVO_SENDER_NAME="${APP_NAME}"
BREVO_SENDER_EMAIL="${MAIL_FROM_ADDRESS}"

# OTP Configuration
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
